<?xml version="1.0"?>
<ruleset name="opensalestax-invoice-ninja">
    <description>PSR-12 coding standard for the OpenSalesTax Invoice Ninja sidecar</description>

    <rule ref="PSR12">
        <!-- We use trailing commas in multi-line argument lists per PHP 8.1+ idiom;
             PSR-12 doesn't forbid them but enforces other formatting we keep. -->
    </rule>

    <file>src</file>
    <file>tests</file>
    <file>bin</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*\.xml$</exclude-pattern>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="p"/>
</ruleset>
