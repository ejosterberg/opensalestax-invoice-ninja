# Example sidecar environment file. Copy to .env and fill in.

# ---- OpenSalesTax engine ----
OST_ENGINE_URL=http://10.32.161.126:8080
# Optional Bearer token if your engine is auth-gated.
# OST_API_KEY=
# Outbound HTTP timeout in seconds (default 10).
# OST_TIMEOUT_SECONDS=10

# ---- Invoice Ninja v5 ----
IN_API_URL=https://invoices.example.com
IN_API_TOKEN=replace-with-your-invoice-ninja-api-token

# ---- Webhook signing ----
# HMAC-SHA256 secret shared with whatever signs Invoice Ninja's outgoing
# webhook (either Invoice Ninja itself if your version supports it, or a
# small Laravel middleware shim). Must be at least 32 chars; generate with:
#   openssl rand -hex 32
IN_WEBHOOK_SIGNING_SECRET=replace-with-a-32-plus-char-secret-here

# ---- Sidecar tuning (optional) ----
# Default 1 (allowed) — supports merchant-self-hosted same-VM deployments.
# Set to 0 if the sidecar is exposed to untrusted webhook senders.
# SIDECAR_ALLOW_PRIVATE_NETWORKS=1

# Default 300 — webhooks older than this are rejected as replay.
# SIDECAR_REPLAY_WINDOW_SECONDS=300

# Default 1 — TLS peer-verify on outbound calls. Set 0 only for local dev.
# SIDECAR_TLS_VERIFY=1

# Default 120 — per-source-IP rate limit (requests per minute).
# SIDECAR_RATE_LIMIT_PER_MINUTE=120

# Per-state nexus filter (CP-3, v0.3.0). Comma-separated list of US
# 2-letter state codes (e.g. "MN,WI,IA") the merchant has nexus in.
# When set, the sidecar short-circuits the engine call for any
# invoice whose ship-to / billing state is NOT in this list, leaving
# Invoice Ninja's invoice untaxed (it returns 200 with applied:false,
# reason:nexus_filter_skipped). Empty / unset = filter disabled
# (engine called for every US/USD invoice — pre-v0.3 behavior).
# Missing or unresolvable destination state with the filter active is
# fail-closed (also skipped).
# OST_NEXUS_STATES=
