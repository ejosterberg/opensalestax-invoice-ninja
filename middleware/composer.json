{
    "name": "ejosterberg/opensalestax-invoice-ninja-shim",
    "description": "Laravel package that signs outbound Invoice Ninja v5 webhooks with the X-Sidecar-Signature HMAC-SHA256 header required by the OpenSalesTax sidecar.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["invoice-ninja", "laravel", "webhook", "hmac", "signature", "opensalestax", "tax", "sidecar"],
    "homepage": "https://github.com/ejosterberg/opensalestax-invoice-ninja",
    "authors": [
        {
            "name": "Eric Osterberg",
            "email": "ejosterberg@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.4",
        "guzzlehttp/promises": "^1.5 || ^2.0",
        "guzzlehttp/psr7": "^2.0",
        "illuminate/config": "^9.0 || ^10.0 || ^11.0",
        "illuminate/console": "^9.0 || ^10.0 || ^11.0",
        "illuminate/container": "^9.0 || ^10.0 || ^11.0",
        "illuminate/contracts": "^9.0 || ^10.0 || ^11.0",
        "illuminate/support": "^9.0 || ^10.0 || ^11.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.10",
        "vlucas/phpdotenv": "^5.4"
    },
    "autoload": {
        "psr-4": {
            "EJOsterberg\\OpenSalesTax\\InvoiceNinja\\Shim\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "EJOsterberg\\OpenSalesTax\\InvoiceNinja\\Shim\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EJOsterberg\\OpenSalesTax\\InvoiceNinja\\Shim\\SidecarShimServiceProvider"
            ]
        }
    },
    "scripts": {
        "check": [
            "@test",
            "@stan",
            "@cs",
            "@audit"
        ],
        "test": "phpunit",
        "stan": "phpstan analyse --no-progress",
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "audit": "@composer audit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
